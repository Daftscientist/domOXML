# Optional Microsoft Graph fidelity backend (BYO credentials)
# Copy this file to .env (or export these vars in your shell) before running
# `python -c "from domoxml.core.fidelity import device_login; device_login()"`
# and then `uv run python scripts/fidelity_check.py --backend graph`.

# Azure app (client) ID for a public client app with device-code flow enabled.
DOMOXML_GRAPH_CLIENT_ID=

# Azure tenant ID (or use "common" for multi-tenant flows).
DOMOXML_GRAPH_TENANT_ID=

# Optional: scopes (space-separated). Default is Files.ReadWrite.
DOMOXML_GRAPH_SCOPES=Files.ReadWrite

# Optional: token cache location. Default: ~/.cache/domoxml/msal_token_cache.json
DOMOXML_GRAPH_CACHE=
